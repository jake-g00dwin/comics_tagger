# Ignore everything in these locations.
build/*

# Keep the build directory itself.
!build/

# Allow the hidden file for version control tracking.
!build/.git_dir

.cache/clangd/index
build/.cache/clangd/index
docs/doxygen_docs/latex
docs/doxygen_docs/html

# The tags file is generated for editors from the script.
tags

# Ignore all core dump files, they get generated from testing and segfaults.
*.core
